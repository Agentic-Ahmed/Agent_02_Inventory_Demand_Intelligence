# Copy to .env.local (gitignored) and fill in. All optional — with nothing set,
# the console runs on built-in demo fixtures + a dev tenant/role switcher.

# Point the console at the FastAPI backend (omit to use the demo fixtures).
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Clerk auth. Set BOTH to switch from the dev session to real sign-in/sign-up.
# Create a Clerk app, add Organizations (= tenants) with roles named to match
# ours (planner, buyer, allocator, pricer, analyst, manager), then paste keys.
# Leave blank to keep the dev tenant/role switcher + per-browser onboarding flag.
# IMPORTANT: in a PRODUCTION build these must be set, or /app fails closed (shows an
# "auth not configured" notice) instead of running open — set them in Vercel too.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Escape hatch: intentionally allow the OPEN dev session (no sign-in) in a deployed
# build — e.g. a knowingly-public demo. Leave unset for secure-by-default behavior.
# NEXT_PUBLIC_ALLOW_INSECURE_DEV_AUTH=true
