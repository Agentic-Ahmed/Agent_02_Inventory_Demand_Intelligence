# Per-agent Gemini API keys — one per agent so each gets its own free-tier rate
# limit and clean per-agent metering. Copy this file to backend/.env and fill in.
# NEVER commit backend/.env (it is gitignored).

GEMINI_API_KEY_ORCHESTRATOR=
GEMINI_API_KEY_FORECASTING=
GEMINI_API_KEY_REORDER=
GEMINI_API_KEY_WAREHOUSE=
GEMINI_API_KEY_MARKDOWN=
GEMINI_API_KEY_ANOMALY=

# Observability (optional): set a Logfire write token to send agent + request
# traces to Logfire. Leave blank to keep tracing off. See observability/tracing.py.
LOGFIRE_TOKEN=
LOGFIRE_ENVIRONMENT=production

# Semantic memory / RAG (optional): set a Qdrant Cloud URL + API key to turn on
# long-term, tenant-scoped vector memory. Leave URL blank to disable. See core/memory.py.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=quorum_memory
# Embeddings run on Gemini via LiteLLM; falls back to the orchestrator key if unset.
GEMINI_API_KEY_EMBEDDING=
