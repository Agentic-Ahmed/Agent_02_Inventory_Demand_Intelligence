# Per-agent Gemini API keys — one per agent so each gets its own free-tier rate
# limit and clean per-agent metering. Copy this file to backend/.env and fill in.
# NEVER commit backend/.env (it is gitignored).

GEMINI_API_KEY_ORCHESTRATOR=
GEMINI_API_KEY_FORECASTING=
GEMINI_API_KEY_REORDER=
GEMINI_API_KEY_WAREHOUSE=
GEMINI_API_KEY_MARKDOWN=
GEMINI_API_KEY_ANOMALY=

# Observability (optional): set a Logfire write token to send agent + request
# traces to Logfire. Leave blank to keep tracing off. See observability/tracing.py.
LOGFIRE_TOKEN=
LOGFIRE_ENVIRONMENT=production

# Semantic memory / RAG (optional): set a Qdrant Cloud URL + API key to turn on
# long-term, tenant-scoped vector memory. Leave URL blank to disable. See core/memory.py.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=quorum_memory
# Embeddings run on Gemini via LiteLLM; falls back to the orchestrator key if unset.
GEMINI_API_KEY_EMBEDDING=

# Cache + rate limiting (optional): set an Upstash Redis REST URL + token to cache the
# usage rollup and rate-limit chat per tenant. Leave URL blank to disable. See core/cache.py.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# CACHE_PREFIX=quorum              # namespaces keys (optional)
# USAGE_CACHE_TTL=30               # seconds to cache /api/usage (optional)
# RATE_LIMIT_CHAT_PER_MIN=60       # per-tenant chat requests/min (optional)

# Live weather signal (get_external_signals) via Open-Meteo — no API key needed. Optional:
# set the DEFAULT location the demand-weather signal is read for (a tenant can override
# this per-workspace in Settings -> General; the saved location wins over this default).
# SIGNAL_LATITUDE=40.7128
# SIGNAL_LONGITUDE=-74.0060

# Live integration credentials (secrets vault) — when a tenant connects one of their own
# systems in Settings -> Integrations, the tool calls the endpoint they configured. The
# raw credential is NEVER stored in the app DB (only a masked hint); it lives here instead.
# Pattern: INTEGRATION_SECRET__{TENANT}__{KIND} (upper-cased; non-alphanumerics -> '_').
# Kinds: WMS | ERP | COMMERCE | WAREHOUSE_DATA | SLACK. Unset -> endpoint called w/o auth.
# INTEGRATION_SECRET__ACME__WMS=your-wms-api-key
# INTEGRATION_SECRET__ACME__COMMERCE=your-store-access-token

# Google AP2 (Agent Payments Protocol) — how money-spending tools settle a payment
# (create_purchase_order). Dev mock-settles locally with a signed spend mandate; set
# AP2_ENDPOINT to a real AP2 gateway to settle for real (see integrations/ap2.py).
# AP2_SIGNING_KEY=change-me-in-prod     # HMAC key that signs the spend mandate
# AP2_ENDPOINT=                          # real AP2 gateway base URL (unset -> mock settle)
# AP2_CREDENTIAL=                        # bearer token for the gateway, if it needs one

# Event streaming (optional): set Redpanda/Kafka bootstrap + SASL creds to enable the
# event-driven trigger path (POST /api/events, POST /api/events/drain). See core/events.py.
REDPANDA_BROKERS=
REDPANDA_USERNAME=
REDPANDA_PASSWORD=
# REDPANDA_TOPIC=inventory-events      # optional
# REDPANDA_GROUP=quorum-orchestrator   # optional
# REDPANDA_SASL_MECHANISM=SCRAM-SHA-256   # optional (some clusters use SCRAM-SHA-512)
# CRON_SECRET=                          # if set, /api/events/drain requires X-Cron-Secret
